programa
{
	
	inclua biblioteca Matematica --> mat
	
	funcao inicio()
	{
		
		real km_percorridos, total_pagar
		inteiro dias_alugados
		
		real PRECO_DIARIA = 60.00
		real PRECO_KM = 0.15

		escreva("--- Calculadora de Aluguel de Carros ---\n\n")

		escreva("Por quantos dias o carro foi alugado? ")
		leia(dias_alugados)

		
		escreva("Quantos Km foram percorridos com o carro? ")
		leia(km_percorridos)

	
		total_pagar = (dias_alugados * PRECO_DIARIA) + (km_percorridos * PRECO_KM)

	
		
		escreva("RESUMO DO ALUGUEL\n")
		escreva("Dias alugados: ", dias_alugados, " dia(s) -> R$ ", (dias_alugados * PRECO_DIARIA), "\n")
		escreva("Km rodados: ", km_percorridos, " Km -> R$ ", mat.arredondar(km_percorridos * PRECO_KM, 2), "\n")
		escreva("Total a pagar: R$ ", mat.arredondar(total_pagar, 2), "\n")
	}
}
