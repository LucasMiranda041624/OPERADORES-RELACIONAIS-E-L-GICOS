programa
{
	funcao inicio()
	{
		
		real nota1, nota2, media

		escreva("Digite a primeira nota: ")
		leia(nota1)
		
		escreva("Digite a segunda nota: ")
		leia(nota2)
		
		media = (nota1 + nota2) / 2

			escreva("\nMédia alcançada: ", media, "\n")
		escreva("Resultado: ")
		
		se (media == 10.0)
		{
			escreva("Aprovado com Distinção\n")
		}
		senao se (media >= 7.0)
		{
			escreva("Aprovado\n")
		}
		senao
		{
			escreva("Reprovado\n")
		}
	}
}
