programa
{
	funcao inicio()
	{
		
		real lado1, lado2, lado3

		
		escreva("Digite o comprimento do primeiro lado: ")
		leia(lado1)
		
		escreva("Digite o comprimento do segundo lado: ")
		leia(lado2)
		
		escreva("Digite o comprimento do terceiro lado: ")
		leia(lado3)

		escreva("\n--- Resultado ---\n")

		
		se (lado1 < lado2 + lado3 e lado2 < lado1 + lado3 e lado3 < lado1 + lado2)
		{
		
			se (lado1 == lado2 e lado2 == lado3)
			{
				escreva("Triângulo equilátero\n")
			}
			senao se (lado1 == lado2 ou lado2 == lado3 ou lado1 == lado3)
			{
				escreva("Triângulo isósceles\n")
			}
			senao
			{
				escreva("Triângulo escaleno\n")
			}
		}
		senao
		{
			
			escreva("Não compõem triângulo\n")
		}
	}
}
